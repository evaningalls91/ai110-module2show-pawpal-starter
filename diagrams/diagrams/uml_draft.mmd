classDiagram
    %% PawPal+ domain model: an Owner has Pets, and each Pet has care Tasks.
    %% Keep this file updated so it matches your final implementation.

    class Owner {
        +str name
        +str email
        +int available_minutes
        +dict preferences
        +list~Pet~ pets
        +add_pet(pet) None
        +set_preference(key, value) None
        +available_time() int
    }

    class Pet {
        +str name
        +str species
        +str breed
        +int age
        +list~Task~ tasks
        +add_task(task) None
        +remove_task(task) None
        +list_tasks() list~Task~
    }

    class Task {
        +str title
        +int duration_minutes
        +str priority
        +bool recurring
        +str scheduled_time
        +priority_score() int
        +is_recurring() bool
        +reschedule(time) None
    }

    class DailyPlan {
        +str date
        +Owner owner
        +list~ScheduledTask~ entries
        +int total_minutes
        +add_entry(entry) None
        +remove_entry(entry) None
        +total_duration() int
        +explain() str
    }

    class Scheduler {
        +int available_minutes
        +list~Task~ tasks
        +build_plan(owner, date) DailyPlan
        +sort_tasks() list~Task~
        +filter_by_time() list~Task~
        +resolve_conflicts() None
    }

    class ScheduledTask {
        +Task task
        +str start_time
        +str end_time
        +duration() int
    }

    Owner "1" --> "*" Pet : owns
    Pet "1" --> "*" Task : has
    Owner "1" --> "*" DailyPlan : creates
    Scheduler "1" ..> "1" DailyPlan : builds
    DailyPlan "1" --> "*" ScheduledTask : contains
    ScheduledTask "*" --> "1" Task : wraps

